#!/usr/bin/env bash
set -euo pipefail

topics="${TOPIC:-$HOME/.topics}"
port="${PORT:-8080}"
twitch_poll="${TWITCH_POLL:-20}"

need() {
	command -v "$1" >/dev/null 2>&1 || {
		printf 'missing command: %s\n' "$1" >&2
		exit 1
	}
}

need nc

_last_twitch_title_file="/tmp/service-current-topic-last-twitch-$$"

_twitch_poller() {
	while :; do
		sleep "$twitch_poll"
		[[ -n "${TWITCH_BROADCASTER_ID:-}" ]] || continue
		command -v twitch >/dev/null 2>&1 || continue
		command -v jq >/dev/null 2>&1 || continue

		title="$(twitch api get channels \
			-q "broadcaster_id=$TWITCH_BROADCASTER_ID" 2>/dev/null \
			| jq -r '.data[0].title // empty' 2>/dev/null)" || continue
		[[ -n "$title" ]] || continue

		last="$(cat "$_last_twitch_title_file" 2>/dev/null || true)"
		[[ "$title" != "$last" ]] || continue

		printf '%s\n' "$title" >"$_last_twitch_title_file"

		current="$(sed -n '1p' "$topics" 2>/dev/null || true)"
		[[ "$title" != "$current" ]] || continue

		topic "$title" >/dev/null
	done
}

_twitch_poller &
_twitch_poller_pid=$!
trap 'kill "$_twitch_poller_pid" 2>/dev/null; rm -f "$_last_twitch_title_file"' EXIT

while :; do
	coproc NETCAT { nc -l "$port"; }

	# Read and discard the HTTP request headers.
	while IFS= read -r -u "${NETCAT[0]}" line; do
		[[ "$line" == $'\r' || -z "$line" ]] && break
	done

	topic="$(sed -n '1{s/\r$//;p;}' "$topics" 2>/dev/null || true)"
	topic="$(toemoji <<<"$topic")"

	printf 'HTTP/1.1 200 OK\r\n' >&"${NETCAT[1]}"
	printf 'Content-Type: text/plain; charset=utf-8\r\n' >&"${NETCAT[1]}"
	printf 'Cache-Control: no-cache\r\n' >&"${NETCAT[1]}"
	printf 'Access-Control-Allow-Origin: *\r\n' >&"${NETCAT[1]}"
	printf '\r\n' >&"${NETCAT[1]}"
	printf '%s\n' "$topic" >&"${NETCAT[1]}"

	eval "exec ${NETCAT[1]}>&-"
	eval "exec ${NETCAT[0]}<&-"
	wait "$NETCAT_PID" 2>/dev/null || true
done
