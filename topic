#!/usr/bin/env bash
set -euo pipefail

die() {
	printf 'Error: %s\n' "$*" >&2
	exit 1
}

youtube_token_file() {
	printf '%s\n' "${YOUTUBE_TOKEN_FILE:-$HOME/.config/youtube/token.json}"
}

restream_token_file() {
	printf '%s\n' "${RESTREAM_TOKEN_FILE:-$HOME/.config/restream/token.json}"
}

usage() {
	cat <<'EOF'
Usage:
  topic                   interactive menu to select from topic history
  topic <new topic words...>
  topic <issue-number>

Environment:
  TOPICS                  Path to topics history file (default: ~/.topics)
  TWITCH_BROADCASTER_ID   Twitch broadcaster id

  YOUTUBE_BROADCAST_ID    Optional explicit live broadcast id
  YOUTUBE_BROADCAST_STATUS
                          Optional broadcast status to search first
                          (default: active, then upcoming)

  YOUTUBE_TOKEN_FILE      Path to YouTube OAuth token JSON
                          (default: ~/.config/youtube/token.json)

Notes:
  When given a single number, this script assumes the current
  directory is a git repo and uses gh to look up that issue topic.

  The topics file keeps all unique topics, most recent first.
  Uses fzf for the interactive menu if available, otherwise select.
EOF
	exit "${1:-0}"
}

need() {
	command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

have() {
	command -v "$1" >/dev/null 2>&1
}

github_issue_emoji() {
	local issue labels

	issue="$1"

	labels="$(
		gh issue view "$issue" --json labels --jq '.labels[].name' 2>/dev/null |
			tr '[:upper:]' '[:lower:]'
	)" || return 1

	while IFS= read -r label; do
		case "$label" in
		bug | fix | regression | broken)
			printf ':bug:\n'
			return 0
			;;
		enhancement | feature | feat)
			printf ':sparkles:\n'
			return 0
			;;
		documentation | docs)
			printf ':memo:\n'
			return 0
			;;
		question)
			printf ':thinking:\n'
			return 0
			;;
		help\ wanted | help-wanted)
			printf ':raising_hand:\n'
			return 0
			;;
		good\ first\ issue | beginner | starter)
			printf ':seedling:\n'
			return 0
			;;
		refactor | cleanup | chore)
			printf ':wrench:\n'
			return 0
			;;
		test | tests | testing)
			printf ':white_check_mark:\n'
			return 0
			;;
		performance | perf)
			printf ':zap:\n'
			return 0
			;;
		security)
			printf ':lock:\n'
			return 0
			;;
		ci | cd | build)
			printf ':gear:\n'
			return 0
			;;
		dependencies | dependency | deps)
			printf ':package:\n'
			return 0
			;;
		design | ui | ux)
			printf ':art:\n'
			return 0
			;;
		infra | ops | deployment)
			printf ':construction:\n'
			return 0
			;;
		*) ;;
		esac
	done <<<"$labels"

	printf ':gear:\n'
}

github_issue_topic() {
	local issue out
	issue="$1"

	git rev-parse --is-inside-work-tree >/dev/null 2>&1 ||
		die 'current directory is not inside a git repo'

	out="$(gh issue view "$issue" --json topic --jq .topic 2>/dev/null)" ||
		die "could not get issue #$issue from current repo"

	[[ -n "$out" ]] || die "issue #$issue has no topic"
	printf '%s\n' "$out"
}

load_topics() {
	local file dir
	file="$1"
	dir="${file%/*}"
	[[ "$dir" != "$file" ]] || dir='.'

	mkdir -p "$dir"
	[[ -f "$file" ]] || : >"$file"

	current_topic="$(sed -n '1p' "$file")"
}

save_topics() {
	local file new tmp
	file="$1"
	new="$2"
	tmp="$(mktemp)"

	{
		printf '%s\n' "$new"
		grep -vxF "$new" "$file" 2>/dev/null || true
	} >"$tmp"

	mv "$tmp" "$file"
}

set_github_status() {

	local text emoji message

	text="$*"

	# extract first Unicode character
	emoji="$(printf '%s' "$text" | perl -CSD -ne 'print substr($_,0,1)')"

	# detect if it is an emoji
	if printf '%s' "$emoji" | perl -CSD -ne 'exit(!( /\p{Emoji}/ ))'; then
		message="$(printf '%s' "$text" | perl -CSD -ne 'print substr($_,1)')"
		message="${message#"${message%%[![:space:]]*}"}"
	else
		emoji='💻'
		message="$text"
	fi

	gh api graphql \
		-f query='
mutation($emoji:String!, $message:String!) {
  changeUserStatus(input: {emoji: $emoji, message: $message}) {
    status {
      emoji
      message
    }
  }
}
' \
		-f emoji="$emoji" \
		-f message="$message" >/dev/null
}

set_twitch_category() {
	local topic categories_file pattern category game_id
	topic="$1"
	categories_file="${TWITCH_CATEGORIES_FILE:-$HOME/.config/twitch/categories}"

	[[ -f "$categories_file" ]] || return 0
	[[ -n "${TWITCH_BROADCASTER_ID:-}" ]] || return 0
	command -v twitch >/dev/null 2>&1 || return 0

	while IFS=$'\t' read -r pattern category; do
		[[ -n "$pattern" && "${pattern:0:1}" != '#' ]] || continue
		[[ -n "$category" ]] || continue
		[[ "${topic,,}" =~ $pattern ]] || continue

		game_id="$(twitch api get games \
			-q "name=$category" 2>/dev/null \
			| jq -r '.data[0].id // empty')" || continue
		[[ -n "$game_id" ]] || continue

		twitch api patch channels \
			-q "broadcaster_id=$TWITCH_BROADCASTER_ID" \
			-b "$(jq -cn --arg id "$game_id" '{game_id:$id}')" >/dev/null 2>&1 || true
		return 0
	done <"$categories_file"
}

set_twitch_topic() {
	: "${TWITCH_BROADCASTER_ID:?missing TWITCH_BROADCASTER_ID}"

	local topic out rc body
	topic="$1"
	topic="${topic:0:140}"
	body="$(jq -cn --arg topic "$topic" '{title:$topic}')"

	set +e
	out="$(
		twitch api patch channels \
			-q "broadcaster_id=$TWITCH_BROADCASTER_ID" \
			-b "$body" \
			2>&1
	)"
	rc=$?
	set -e

	[[ $rc != 204 ]] || die "twitch topic update failed: $out"
}

restream_api() {
	local method endpoint
	method="$1"
	endpoint="$2"
	shift 2

	cache-restream-token
	local token_file access_token
	token_file="$(restream_token_file)"
	access_token="$(jq -r .access_token "$token_file")"

	[[ -n "$access_token" ]] || {
		printf 'failed to get access_token from %s\n' "$token_file" >&2
		return 1
	}

	curl --silent --show-error --fail \
		-X "$method" \
		-H "Authorization: Bearer $access_token" \
		-H 'Accept: application/json' \
		"$@" \
		"https://api.restream.io/v2/$endpoint"
}

set_restream_topic() {
	local topic channels channel_id
	topic="$1"

	channels="$(restream_api GET 'user/channel/all')" || return 1

	while IFS= read -r channel_id; do
		[[ -n "$channel_id" ]] || continue
		restream_api PATCH "user/channel-meta/$channel_id" \
			-H 'Content-Type: application/json' \
			--data "$(jq -cn --arg title "$topic" '{title:$title}')" >/dev/null || true
	done < <(jq -r '.[].id' <<<"$channels")
}

youtube_api() {
	local method endpoint
	method="$1"
	endpoint="$2"
	shift 2

	cache-yt-token
	token_file=$(youtube_token_file)
	access_token="$(jq -r .access_token "$token_file")"

	[[ -n "$access_token" ]] || {
		printf 'failed to get access_token from %s\n' "$token_file" >&2
		return 1
	}

	curl --silent --show-error --fail \
		-X "$method" \
		-H "Authorization: Bearer $access_token" \
		-H 'Accept: application/json' \
		"$@" \
		"https://www.googleapis.com/youtube/v3/$endpoint"
}

youtube_find_broadcast_id() {
	local json

	json="$(
		youtube_api GET \
			'liveBroadcasts?part=id,snippet,status&mine=true&broadcastType=all&maxResults=10'
	)" || return 1

	jq -r '
 			.items
 			| (map(select(
 				.status.lifeCycleStatus == "live" or
 				.status.lifeCycleStatus == "ready" or
 				.status.lifeCycleStatus == "created"
 			))[0].id)
 			  // .[0].id
 			  // empty
 		' <<<"$json"
}

youtube_get_broadcast() {
	local id
	id="$1"

	youtube_api GET \
		"liveBroadcasts?part=id,snippet,status&id=$id"
}

set_youtube_live_topic() {

	local topic_arg id json body preferred_status
	topic_arg="$1"
	preferred_status="${YOUTUBE_BROADCAST_STATUS:-active}"

	if [[ -n "${YOUTUBE_BROADCAST_ID:-}" ]]; then
		id="$YOUTUBE_BROADCAST_ID"
	else
		id="$(youtube_find_broadcast_id "$preferred_status" || true)"
	fi

	[[ -n "$id" ]] || die 'could not find a YouTube live broadcast to update'

	json="$(youtube_get_broadcast "$id")" ||
		die "could not fetch YouTube broadcast $id"
	body="$(
		printf '%s\n' "$json" |
			jq -c --arg topic "$topic_arg" '
				.items[0]
				| {
					id,
					snippet: (.snippet + {title: $topic})
				}
			'
	)"

	[[ -n "$body" && "$body" != "null" ]] ||
		die "could not build update body for YouTube broadcast $id"

	youtube_api PUT \
		'liveBroadcasts?part=snippet' \
		-H 'Content-Type: application/json' \
		--data "$body" >/dev/null ||
		die "could not update the youtube topic"
}

main() {
	local topics_file new_topic

	need git
	need gh
	need jq
	need curl

	topics_file="${TOPICS:-$HOME/.topics}"

	load_topics "$topics_file"

	if [[ $# -eq 0 ]]; then
		[[ -s "$topics_file" ]] || die 'no topics history'
		if have fzf; then
			new_topic="$(fzf --prompt='topic> ' <"$topics_file")" || exit 0
		else
			mapfile -t _topics <"$topics_file"
			local i width choice
			width="${#_topics[@]}"
			width="${#width}"
			for ((i = 0; i < ${#_topics[@]}; i++)); do
				printf "%${width}d) %s\n" "$((i + 1))" "${_topics[$i]}"
			done >&2
			printf 'Select topic: ' >&2
			read -r choice
			[[ "$choice" =~ ^[0-9]+$ ]] || exit 0
			((choice >= 1 && choice <= ${#_topics[@]})) || exit 0
			new_topic="${_topics[$((choice - 1))]}"
		fi
	elif [[ $# -eq 1 && "$1" == "-" ]]; then
		new_topic="$(grep -vxF "$current_topic" "$topics_file" | head -1)"
		[[ -n "$new_topic" ]] || die 'no previous topic to toggle to'
	elif [[ $# -eq 1 && "$1" =~ ^[0-9]+$ ]]; then
		issue_topic="$(github_issue_topic "$1")"
		issue_emoji="$(github_issue_emoji "$1")"
		new_topic="$issue_emoji $issue_topic"
	else
		new_topic="$*"
	fi

	if [[ "$new_topic" == "$current_topic" ]]; then
		echo "Title already set"
		exit 0
	fi

	save_topics "$topics_file" "$new_topic"
	set_github_status "$new_topic"
	set_twitch_topic "$new_topic"
	set_twitch_category "$new_topic"
	set_restream_topic "$new_topic"
	set_youtube_live_topic "$new_topic"
	head -1 "$topics_file"
}

main "$@"
