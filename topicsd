#!/usr/bin/env bash
set -uo pipefail

topics="${TOPICS:-${TOPIC:-$HOME/.topics}}"
port="${PORT:-8080}"
obs_ws_url="${OBS_WS_URL:-ws://127.0.0.1:4455}"
obs_ws_password_file="${OBS_WS_PASSWORD_FILE:-$HOME/.config/obs-websocket/password}"
obs_reconnect_delay="${RECONNECT_DELAY:-2}"
log_prefix="${LOG_PREFIX:-topic-service}"
_vid_dir=Videos; [[ $(uname) == Darwin ]] && _vid_dir=Movies
clips_dir="${CLIPS_DIR:-$HOME/$_vid_dir/twclips}"
clips_sync_interval="${CLIPS_SYNC_INTERVAL:-3600}"
obs_clips_scene="${OBS_CLIPS_SCENE:-Clips}"
obs_live_scene="${OBS_LIVE_SCENE:-IRL-Moblin}"
obs_live_scene_file="${OBS_LIVE_SCENE_FILE:-${XDG_STATE_HOME:-$HOME/.local/state}/topicsd-live-scene}"
obs_belabox_source="${OBS_BELABOX_SOURCE:-Belabox}"
obs_belabox_debounce="${OBS_BELABOX_DEBOUNCE:-5}"
obs_belabox_stable="${OBS_BELABOX_STABLE:-30}"
obs_vlc_source="${OBS_VLC_SOURCE:-VLC Video}"
obs_clips_reward="${OBS_CLIPS_REWARD:-play clip}"

need() {
	command -v "$1" >/dev/null 2>&1 || {
		printf '%s: missing command: %s\n' "$log_prefix" "$1" >&2
		exit 1
	}
}

log() {
	printf '%s: %s\n' "$log_prefix" "$*" >&2
}

# --- OBS recording rename ---------------------------------------------------

trim_cr() {
	sed 's/\r$//'
}

load_password() {
	if [[ -f "$obs_ws_password_file" ]]; then
		OBS_WS_PASSWORD="$(tr -d '\r\n' <"$obs_ws_password_file")"
	else
		OBS_WS_PASSWORD=""
	fi
}

strip_leading_emoji() {
	local s="$1"

	case "$s" in
	:[A-Za-z0-9_+-]*:[[:space:]]*)
		s="${s#*:}"
		s="${s#*:}"
		s="${s## }"
		;;
	esac

	printf '%s\n' "$s"
}

slugify() {
	local s
	s="$(strip_leading_emoji "$1")"

	s="$(
		printf '%s' "$s" |
			tr '[:upper:]' '[:lower:]' |
			sed \
				-e 's/[^a-z0-9]/-/g' \
				-e 's/-\{2,\}/-/g' \
				-e 's/^-//' \
				-e 's/-$//'
	)"

	[[ -n "$s" ]] || s="untopic-recording"
	printf '%s\n' "$s"
}

b64sha256() {
	openssl dgst -binary -sha256 | openssl base64 -A
}

obs_auth_string() {
	local password salt challenge secret
	password="$1"
	salt="$2"
	challenge="$3"

	secret="$(printf '%s%s' "$password" "$salt" | b64sha256)"
	printf '%s%s' "$secret" "$challenge" | b64sha256
}

current_topic() {
	sed -n '1{s/\r$//;p;}' "$topics" 2>/dev/null || true
}

sanitize_filename() {
	local s
	s="$1"
	s="${s//\//-}"
	s="${s//:/ -}"
	s="$(printf '%s' "$s" |
		tr '\n' ' ' |
		sed \
			-e 's/[[:cntrl:]]//g' \
			-e 's/[[:space:]]\+/ /g' \
			-e 's/^[[:space:]]*//' \
			-e 's/[[:space:]]*$//')"

	[[ -n "$s" ]] || s="Untopic recording"
	printf '%s\n' "$s"
}

target_path_for() {
	local src dir base ext topic slug dest n
	src="$1"
	dir="${src%/*}"
	base="${src##*/}"

	[[ "$src" != "$dir" ]] || dir="."

	if [[ "$base" == *.* ]]; then
		ext=".${base##*.}"
	else
		ext=""
	fi

	topic="$(current_topic)"
	slug="$(slugify "$topic")"
	dest="$dir/$slug$ext"

	[[ "$dest" != "$src" ]] || { printf '%s\n' "$dest"; return 0; }
	[[ -e "$dest" ]] || { printf '%s\n' "$dest"; return 0; }

	n=2
	while [[ -e "$dir/$slug-$n$ext" ]]; do
		n=$((n + 1))
	done
	printf '%s\n' "$dir/$slug-$n$ext"
}

rename_recording() {
	local src dest
	src="$1"

	[[ -n "$src" && "$src" != "null" ]] || return 0
	[[ -e "$src" ]] || { log "recording file not found: $src"; return 0; }

	dest="$(target_path_for "$src")"

	if [[ "$dest" == "$src" ]]; then
		log "already named correctly: $src"
		return 0
	fi

	mv -- "$src" "$dest"
	log "renamed:"
	log "  from: $src"
	log "    to: $dest"
}

obs_send_request() {
	local request_type="$1" request_data="${2:-{}}"
	"$(dirname "$0")/obs-req" "$obs_ws_url" "$request_type" "$request_data" 2>>"${TOPICS_LOG:-/tmp/topicsd-obs.log}" || true
}

obs_connect_and_watch() {
	local hello salt challenge auth identify line op event_type input_name output_path rc
	local _current_scene="" _prev_scene="" _clip_req_active=0
	local _belabox_ended_at=0 _belabox_restore_at=0

	load_password

	coproc OBSWS { websocat --text --no-close "$obs_ws_url"; }

	IFS= read -r -u "${OBSWS[0]}" hello || {
		log "failed to read Hello from OBS"
		return 1
	}
	hello="$(printf '%s' "$hello" | trim_cr)"

	challenge="$(jq -r '.d.authentication.challenge // empty' <<<"$hello")"
	salt="$(jq -r '.d.authentication.salt // empty' <<<"$hello")"

	if [[ -n "$challenge" || -n "$salt" ]]; then
		[[ -n "$OBS_WS_PASSWORD" ]] || {
			log "OBS requires auth, but password file is empty: $obs_ws_password_file"
			return 1
		}
		auth="$(obs_auth_string "$OBS_WS_PASSWORD" "$salt" "$challenge")"
		identify="$(jq -cn --arg auth "$auth" \
			'{op:1,d:{rpcVersion:1,authentication:$auth,eventSubscriptions:324}}')"
	else
		identify="$(jq -cn '{op:1,d:{rpcVersion:1,eventSubscriptions:324}}')"
	fi

	printf '%s\n' "$identify" >&"${OBSWS[1]}"

	IFS= read -r -u "${OBSWS[0]}" line || {
		log "failed to read Identified from OBS"
		return 1
	}
	line="$(printf '%s' "$line" | trim_cr)"

	if [[ "$(jq -r '.op // empty' <<<"$line")" != "2" ]]; then
		log "unexpected identify response: $line"
		return 1
	fi

	log "connected to OBS at $obs_ws_url"

	printf '%s\n' '{"op":6,"d":{"requestType":"GetCurrentProgramScene","requestId":"init-scene","requestData":{}}}' >&"${OBSWS[1]}"

	while :; do
		line=""
		IFS= read -r -u "${OBSWS[0]}" -t 1 line
		rc=$?

		if [[ $rc -ne 0 ]]; then
			kill -0 "${OBSWS_PID:-0}" 2>/dev/null || break
			now=$(date +%s)
			if [[ $_belabox_ended_at -gt 0 ]] && (( now - _belabox_ended_at >= obs_belabox_debounce )); then
				obs_send_request "SetCurrentProgramScene" \
					"$(jq -cn --arg n "$obs_clips_scene" '{sceneName:$n}')"
				obs_send_request "TriggerMediaInputAction" \
					"$(jq -cn --arg n "$obs_vlc_source" '{inputName:$n,mediaAction:"OBS_WEBSOCKET_MEDIA_INPUT_ACTION_RESTART"}')"
				log "belabox down ${obs_belabox_debounce}s: switched to $obs_clips_scene"
				_belabox_ended_at=0
				_current_scene="$obs_clips_scene"
			fi
			if [[ $_belabox_restore_at -gt 0 ]] && (( now - _belabox_restore_at >= obs_belabox_stable )); then
				obs_send_request "SetCurrentProgramScene" \
					"$(jq -cn --arg n "$_prev_scene" '{sceneName:$n}')"
				log "belabox stable: restored to $_prev_scene"
				_current_scene="$_prev_scene"
				_prev_scene=""
				_belabox_restore_at=0
			fi
		fi

		if [[ -n "$line" ]]; then
			line="$(printf '%s' "$line" | trim_cr)"
			[[ "$line" == "{"* ]] || continue
			op="$(jq -r '.op // empty' 2>/dev/null <<<"$line")"

			if [[ "$op" == "7" ]]; then
				local req_type
				req_type="$(jq -r '.d.requestType // empty' <<<"$line")"
				if [[ "$req_type" == "GetCurrentProgramScene" ]]; then
					_current_scene="$(jq -r '.d.responseData.currentProgramSceneName // empty' <<<"$line")"
					if [[ "$_current_scene" == "$obs_clips_scene" && -z "$_prev_scene" ]]; then
						if [[ -r "$obs_live_scene_file" ]]; then
							_prev_scene="$(cat "$obs_live_scene_file")"
						else
							_prev_scene="$obs_live_scene"
						fi
					fi
				fi

			elif [[ "$op" == "5" ]]; then
				event_type="$(jq -r '.d.eventType // empty' <<<"$line")"

				case "$event_type" in
				RecordStateChanged)
					output_path="$(jq -r '.d.eventData.outputPath // empty' <<<"$line")"
					[[ -n "$output_path" ]] && rename_recording "$output_path"
					;;
				CurrentProgramSceneChanged)
					_current_scene="$(jq -r '.d.eventData.sceneName // empty' <<<"$line")"
					;;
				MediaInputPlaybackEnded|MediaInputPlaybackStarted)
					input_name="$(jq -r '.d.eventData.inputName // empty' <<<"$line")"
					log "obs event: $event_type inputName='$input_name' (want '$obs_belabox_source')"
					;;&
				MediaInputPlaybackEnded)
					input_name="$(jq -r '.d.eventData.inputName // empty' <<<"$line")"
					if [[ "$input_name" == "$obs_belabox_source" ]]; then
						log "belabox down"
						_belabox_restore_at=0
						if [[ $_belabox_ended_at -eq 0 && -n "$_current_scene" \
							&& "$_current_scene" != "$obs_clips_scene" ]]; then
							_prev_scene="$_current_scene"
							mkdir -p "$(dirname "$obs_live_scene_file")"
							printf '%s\n' "$_prev_scene" > "$obs_live_scene_file"
							_belabox_ended_at=$(date +%s)
							log "belabox ended: waiting ${obs_belabox_debounce}s before switching"
						fi
					elif [[ "$input_name" == "$obs_vlc_source" && $_clip_req_active -eq 1 ]]; then
						obs_send_request "SetInputSettings" \
							"$(jq -cn --arg n "$obs_vlc_source" --arg p "$clips_dir/clips.m3u" \
								'{inputName:$n,inputSettings:{playlist:[{value:$p,hidden:false,selected:false}]}}')"
						obs_send_request "TriggerMediaInputAction" \
							"$(jq -cn --arg n "$obs_vlc_source" '{inputName:$n,mediaAction:"OBS_WEBSOCKET_MEDIA_INPUT_ACTION_RESTART"}')"
						if [[ -n "$_prev_scene" ]]; then
							obs_send_request "SetCurrentProgramScene" \
								"$(jq -cn --arg n "$_prev_scene" '{sceneName:$n}')"
							log "clip request done: restored to $_prev_scene"
							_prev_scene=""
						fi
						_clip_req_active=0
					fi
					;;
				MediaInputPlaybackStarted)
					input_name="$(jq -r '.d.eventData.inputName // empty' <<<"$line")"
					if [[ "$input_name" == "$obs_belabox_source" ]]; then
						log "belabox up"
						if [[ "$_current_scene" == "$obs_clips_scene" && -n "$_prev_scene" ]]; then
							_belabox_restore_at=$(date +%s)
						fi
					fi
					;;
				esac
			fi
		fi

		local req_file="$clips_dir/clip-request"
		if [[ -f "$req_file" && $_clip_req_active -eq 0 ]]; then
			local req_id
			req_id="$(cat "$req_file" 2>/dev/null || true)"
			rm -f "$req_file"
			if [[ -n "$req_id" ]]; then
				local req_mp4="$clips_dir/$req_id.mp4"
				if [[ -f "$req_mp4" ]]; then
					printf '%s\n' "$req_mp4" >"$clips_dir/clips-request.m3u"
					_prev_scene="$_current_scene"
					obs_send_request "SetInputSettings" \
						"$(jq -cn --arg n "$obs_vlc_source" --arg p "$clips_dir/clips-request.m3u" \
							'{inputName:$n,inputSettings:{playlist:[{value:$p,hidden:false,selected:false}]}}')"
					obs_send_request "TriggerMediaInputAction" \
						"$(jq -cn --arg n "$obs_vlc_source" '{inputName:$n,mediaAction:"OBS_WEBSOCKET_MEDIA_INPUT_ACTION_RESTART"}')"
					obs_send_request "SetCurrentProgramScene" \
						"$(jq -cn --arg n "$obs_clips_scene" '{sceneName:$n}')"
					_clip_req_active=1
					log "playing requested clip: $req_id"
				else
					log "requested clip not found locally: $req_id"
				fi
			fi
		fi
	done

	return 1
}

_obs_watcher() {
	while :; do
		command -v websocat >/dev/null 2>&1 || { sleep 5; continue; }
		command -v jq >/dev/null 2>&1 || { sleep 5; continue; }
		command -v openssl >/dev/null 2>&1 || { sleep 5; continue; }

		if ! obs_connect_and_watch; then
			log "disconnected; reconnecting in ${obs_reconnect_delay}s"
			sleep "$obs_reconnect_delay"
		fi
	done
}

# --- Twitch EventSub --------------------------------------------------------

_twitch_eventsub() {
	local session_id title current line welcome

	while :; do
		[[ -n "${TWITCH_BROADCASTER_ID:-}" ]] || { sleep 5; continue; }
		command -v websocat >/dev/null 2>&1 || { sleep 5; continue; }
		command -v jq >/dev/null 2>&1 || { sleep 5; continue; }
		command -v twitch >/dev/null 2>&1 || { sleep 5; continue; }

		coproc WS { websocat --text --no-close 'wss://eventsub.wss.twitch.tv/ws'; }

		IFS= read -r -u "${WS[0]}" welcome || {
			eval "exec ${WS[1]}>&-" 2>/dev/null
			sleep 2; continue
		}

		session_id="$(jq -r '.payload.session.id // empty' <<<"$welcome")"
		[[ -n "$session_id" ]] || {
			eval "exec ${WS[1]}>&-" 2>/dev/null
			sleep 2; continue
		}

		twitch api post eventsub/subscriptions -b "$(jq -cn \
			--arg bid "$TWITCH_BROADCASTER_ID" \
			--arg sid "$session_id" \
			'{type:"channel.update",version:"2",condition:{broadcaster_user_id:$bid},transport:{method:"websocket",session_id:$sid}}'
		)" >/dev/null 2>&1 || {
			eval "exec ${WS[1]}>&-" 2>/dev/null
			sleep 2; continue
		}

		if [[ -n "${obs_clips_reward:-}" ]]; then
			twitch api post eventsub/subscriptions -b "$(jq -cn \
				--arg bid "$TWITCH_BROADCASTER_ID" \
				--arg sid "$session_id" \
				'{type:"channel.channel_points_custom_reward_redemption.add",version:"1",condition:{broadcaster_user_id:$bid},transport:{method:"websocket",session_id:$sid}}'
			)" >/dev/null 2>&1 || true
		fi

		while IFS= read -r -u "${WS[0]}" line; do
			[[ -n "$line" ]] || continue
			[[ "$(jq -r '.metadata.message_type // empty' <<<"$line")" == "notification" ]] || continue

			sub_type="$(jq -r '.metadata.subscription_type // empty' <<<"$line")"

			case "$sub_type" in
			channel.update)
				title="$(jq -r '.payload.event.title // empty' <<<"$line")"
				[[ -n "$title" ]] || continue

				current="$(sed -n '1p' "$topics" 2>/dev/null || true)"
				[[ "$title" != "$current" ]] || continue

				topic "$title" >/dev/null
				;;
			channel.channel_points_custom_reward_redemption.add)
				[[ -n "${obs_clips_reward:-}" ]] || continue
				reward_title="$(jq -r '.payload.event.reward.title // empty' <<<"$line")"
				[[ "$reward_title" == "$obs_clips_reward" ]] || continue

				user_input="$(jq -r '.payload.event.user_input // empty' <<<"$line")"
				[[ "$user_input" =~ ^[0-9]+$ ]] || continue

				clip_twitch_id="$(sqlite3 "$clips_dir/clips.db" \
					"SELECT slug FROM clips WHERE id=$user_input AND downloaded=1 AND slug!='' LIMIT 1;" \
					2>/dev/null || true)"
				[[ -n "$clip_twitch_id" ]] || {
					log "clip #$user_input not found or not downloaded"
					continue
				}

				printf '%s\n' "$clip_twitch_id" >"$clips_dir/clip-request"
				log "clip request queued: #$user_input ($clip_twitch_id)"
				;;
			esac
		done

		eval "exec ${WS[1]}>&-" 2>/dev/null
		sleep 2
	done
}

# --- Clips syncer -----------------------------------------------------------

_clips_syncer() {
	while :; do
		command -v twitch >/dev/null 2>&1 || { sleep 10; continue; }
		[[ -n "${TWITCH_BROADCASTER_ID:-}" ]] || { sleep 10; continue; }
		sync-clips >/dev/null 2>&1 || true
		sleep "$clips_sync_interval"
	done
}

# --- Main -------------------------------------------------------------------

need nc

_twitch_eventsub &
_eventsub_pid=$!
_obs_watcher &
_obs_pid=$!
_clips_syncer &
_clips_pid=$!
trap 'kill "$_eventsub_pid" "$_obs_pid" "$_clips_pid" 2>/dev/null' EXIT

while :; do
	coproc NETCAT { nc -l "$port"; } 2>/dev/null || { sleep 1; continue; }

	while IFS= read -r -u "${NETCAT[0]}" line; do
		[[ "$line" == $'\r' || -z "$line" ]] && break
	done

	topic="$(sed -n '1{s/\r$//;p;}' "$topics" 2>/dev/null || true)"
	topic="$(toemoji <<<"$topic" 2>/dev/null || printf '%s' "$topic")"

	printf 'HTTP/1.1 200 OK\r\n' >&"${NETCAT[1]}" 2>/dev/null || { eval "exec ${NETCAT[1]}>&-" 2>/dev/null; eval "exec ${NETCAT[0]}<&-" 2>/dev/null; wait "$NETCAT_PID" 2>/dev/null || true; continue; }
	printf 'Content-Type: text/plain; charset=utf-8\r\n' >&"${NETCAT[1]}"
	printf 'Cache-Control: no-cache\r\n' >&"${NETCAT[1]}"
	printf 'Connection: close\r\n' >&"${NETCAT[1]}"
	printf 'Access-Control-Allow-Origin: *\r\n' >&"${NETCAT[1]}"
	printf '\r\n' >&"${NETCAT[1]}"
	printf '%s\n' "$topic" >&"${NETCAT[1]}"

	eval "exec ${NETCAT[1]}>&-"
	eval "exec ${NETCAT[0]}<&-"
	wait "$NETCAT_PID" 2>/dev/null || true
done
